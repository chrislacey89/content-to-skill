		display: flex;
		flex-direction: column;
		align-items: center;
	}

	/* Connectors */
	.wf-conn {
		width: 1px;
		height: 32px;
		position: relative;
		overflow: visible;
		background: rgba(162, 144, 112, 0.15);
	}
	.wf-conn::after {
		content: '';
		position: absolute;
		width: 5px; height: 5px;
		border-radius: 50%;
		background: #a89070;
		bottom: -2px; left: -2px;
		opacity: 0.6;
	}
	.wf-conn-nodot::after { display: none }
	.wf-conn-terra { background: rgba(194, 83, 45, 0.25) }
	.wf-conn-terra::after { background: rgba(194, 83, 45, 0.6) }
	.wf-conn-long { height: 44px }

	/* Nodes */
	.wf-node {
		position: relative;
		border-radius: 10px;
		padding: 18px 24px;
		border: 1px solid rgba(162, 144, 112, 0.15);
		background: rgba(30, 26, 22, 0.85);
		text-align: center;
		transition: transform 0.2s ease, box-shadow 0.2s ease;
		max-width: 320px;
	}
	.wf-node:hover {
		transform: translateY(-2px);
		box-shadow: 0 8px 32px rgba(0,0,0,0.3);
		z-index: 10;
	}
	.wf-label {
		font-family: 'Lora', serif;
		font-size: 0.9rem;
		font-weight: 600;
		color: #d4c4a8;
		line-height: 1.3;
	}
	.wf-detail {
		font-family: 'JetBrains Mono', monospace;
		font-size: 0.6rem;
		font-weight: 300;
		color: #6b5c4a;
		margin-top: 6px;
		line-height: 1.6;
	}
	.wf-badge {
		font-family: 'Old Standard TT', serif;
		display: inline-block;
		font-size: 0.55rem;
		letter-spacing: 0.15em;
		text-transform: uppercase;
		padding: 2px 10px;
		border-radius: 100px;
		margin-bottom: 8px;
		color: #a89070;
		border: 1px solid rgba(162, 144, 112, 0.15);
	}

	/* Node variants */
	.wf-input {
		border-color: rgba(194, 83, 45, 0.3);
		background: rgba(194, 83, 45, 0.1);
		border-radius: 40px;
		padding: 16px 32px;
	}
	.wf-input .wf-label { color: #c2532d }
	.wf-input .wf-badge { color: #c2532d; border-color: rgba(194, 83, 45, 0.3) }
	.wf-input:hover { box-shadow: 0 0 24px rgba(194, 83, 45, 0.1) }

	.wf-decision {
		border-color: rgba(194, 83, 45, 0.3);
		background: rgba(194, 83, 45, 0.1);
		border-radius: 4px;
		transform: rotate(45deg);
		width: 80px; height: 80px;
		display: flex;
		align-items: center;
		justify-content: center;
		padding: 0;
		margin-top: 17px;
	}
	.wf-decision .wf-label {
		transform: rotate(-45deg);
		color: #c2532d;
		font-size: 0.7rem;
		white-space: nowrap;
	}
	.wf-decision:hover { transform: rotate(45deg) translateY(-2px); box-shadow: 0 0 20px rgba(194, 83, 45, 0.1) }

	.wf-process .wf-label { color: #d4c4a8 }

	.wf-ai {
		border-color: rgba(194, 83, 45, 0.3);
		background: rgba(194, 83, 45, 0.1);
	}
	.wf-ai .wf-label { color: #c2532d }
	.wf-ai .wf-badge { color: #c2532d; border-color: rgba(194, 83, 45, 0.3) }
	.wf-ai:hover { box-shadow: 0 0 24px rgba(194, 83, 45, 0.1) }

	.wf-dots {
		display: flex;
		gap: 5px;
		justify-content: center;
		margin-top: 8px;
	}
	.wf-dots span {
		width: 4px; height: 4px;
		border-radius: 50%;
		background: #c2532d;
		opacity: 0.5;

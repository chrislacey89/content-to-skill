		max-width: 500px;
		margin: 24px auto;
	}

	@media (max-width: 768px) {
		.wf-canvas { padding: 20px 12px 40px }
		.wf-fork { gap: 20px }
		.wf-node { padding: 14px 16px }
		.wf-label { font-size: 0.78rem !important }
	}
</style>

<script>
	// Copy buttons
	document.querySelectorAll(".copy-btn").forEach((btn) => {
		btn.addEventListener("click", async () => {
			const text = btn.getAttribute("data-copy");
			if (text) {
				await navigator.clipboard.writeText(text);
				btn.classList.add("copied");
				setTimeout(() => btn.classList.remove("copied"), 1500);
			}
		});
	});

	// Workflow fork lines (decision → pipeline columns)
	function drawWfFork() {
		const decision = document.getElementById('wf-decision');
		const bookPipe = document.getElementById('wf-book-pipeline');
		const repoPipe = document.getElementById('wf-repo-pipeline');
		const container = document.getElementById('wf-fork-lines-container');
		const canvas = document.querySelector('.wf-canvas');

		if (!decision || !bookPipe || !repoPipe || !container || !canvas) return;

		const canvasRect = canvas.getBoundingClientRect();
		const cw = container.getBoundingClientRect().width;
		const ch = 44;

		// Decision bottom center (relative to container)
		const containerRect = container.getBoundingClientRect();
		const decRect = decision.getBoundingClientRect();
		const dx = decRect.left + decRect.width / 2 - containerRect.left;

		// Pipeline column centers (relative to container)
		const bookRect = bookPipe.getBoundingClientRect();
		const bx = bookRect.left + bookRect.width / 2 - containerRect.left;

		const repoRect = repoPipe.getBoundingClientRect();
		const rx = repoRect.left + repoRect.width / 2 - containerRect.left;

		container.innerHTML = `<svg viewBox="0 0 ${cw} ${ch}" style="width:100%;height:100%;overflow:visible;">
			<path d="M ${dx} 0 C ${dx} ${ch * 0.5}, ${bx} ${ch * 0.5}, ${bx} ${ch}" stroke="#c2532d" stroke-width="1" fill="none" opacity="0.3" stroke-dasharray="5 4"/>
			<path d="M ${dx} 0 C ${dx} ${ch * 0.5}, ${rx} ${ch * 0.5}, ${rx} ${ch}" stroke="#c2532d" stroke-width="1" fill="none" opacity="0.3" stroke-dasharray="5 4"/>
		</svg>`;
	}

	drawWfFork();
	window.addEventListener('resize', drawWfFork);

	// Workflow merge lines
	function drawWfMerge() {
		const book = document.getElementById('wf-book-synth');
		const repo = document.getElementById('wf-repo-synth');
		const target = document.getElementById('wf-merge-target');
		const svg = document.getElementById('wf-merge-line');
		const canvas = document.querySelector('.wf-canvas');

		if (!book || !repo || !target || !svg || !canvas) return;

		const canvasRect = canvas.getBoundingClientRect();
		svg.style.width = canvasRect.width + 'px';
		svg.style.height = canvasRect.height + 'px';
		svg.setAttribute('viewBox', `0 0 ${canvasRect.width} ${canvasRect.height}`);

		const targetRect = target.getBoundingClientRect();
		const tx = targetRect.left + targetRect.width / 2 - canvasRect.left;
		const ty = targetRect.top - canvasRect.top;

		const gap = 14;

		const bookRect = book.getBoundingClientRect();
		const bx = bookRect.left + bookRect.width / 2 - canvasRect.left;
		const by = bookRect.bottom - canvasRect.top + gap;
		const bMidY = by + (ty - by) * 0.6;
		const bookPath = `M ${bx} ${by} C ${bx} ${bMidY}, ${tx} ${bMidY}, ${tx} ${ty}`;

		const repoRect = repo.getBoundingClientRect();
		const rx = repoRect.left + repoRect.width / 2 - canvasRect.left;
		const ry = repoRect.bottom - canvasRect.top + gap;
		const rMidY = ry + (ty - ry) * 0.6;
		const repoPath = `M ${rx} ${ry} C ${rx} ${rMidY}, ${tx} ${rMidY}, ${tx} ${ty}`;

		svg.innerHTML = `
			<path d="${bookPath}" stroke="#c2532d" stroke-width="1" fill="none" opacity="0.3" stroke-dasharray="5 4"/>
			<path d="${repoPath}" stroke="#c2532d" stroke-width="1" fill="none" opacity="0.3" stroke-dasharray="5 4"/>
		`;
	}

	drawWfMerge();
	window.addEventListener('resize', drawWfMerge);
</script>

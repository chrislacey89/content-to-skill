		justify-content: space-between;
		width: 100%;
		max-width: 440px;
		margin-top: -4px;
		margin-bottom: 4px;
	}
	.wf-fork-label {
		font-family: 'Old Standard TT', serif;
		font-size: 0.6rem;
		color: #6b5c4a;
		letter-spacing: 0.15em;
		text-transform: uppercase;
	}
	.wf-section-label {
		font-family: 'Old Standard TT', serif;
		font-size: 0.7rem;
		color: #a89070;
		letter-spacing: 0.2em;
		text-transform: uppercase;
		margin-top: 10px;
		margin-bottom: 6px;
	}

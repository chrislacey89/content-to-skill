---
import {
	hero,
	problem,
	pipelineIntro,
	pipeline,
	install,
	benchmark,
	output,
	companion,
	plugin,
	author,
} from "../../lib/content";
---

<div class="design-panel" data-design="18">
	<!-- Hero -->
	<section class="min-h-[80vh] flex items-center justify-center px-6 py-24">
		<div class="max-w-2xl mx-auto text-center">
			<p
				class="text-xs uppercase tracking-[0.3em] mb-6"
				style="font-family: 'Old Standard TT', serif; color: #a89070;"
			>
				Claude Code Plugin
			</p>
			<h1
				class="text-6xl sm:text-7xl font-normal mb-6 leading-[1.1]"
				style="font-family: 'Lora', serif; color: #f5f0e8;"
			>
				{hero.title}
			</h1>
			<p
				class="text-xl sm:text-2xl mb-8 leading-relaxed"
				style="font-family: 'Lora', serif; color: #c2532d;"
			>
				{hero.tagline}
			</p>
			<p
				class="text-base leading-relaxed max-w-lg mx-auto"
				style="font-family: 'Old Standard TT', serif; color: #a89070;"
			>
				{hero.description}
			</p>
		</div>
	</section>

	<!-- Divider -->
	<div class="max-w-2xl mx-auto px-6">
		<hr style="border-color: rgba(162, 144, 112, 0.2);" />
	</div>

	<!-- Chapter I: The Problem -->
	<section class="px-6 py-20">
		<div class="max-w-2xl mx-auto">
			<p
				class="text-xs uppercase tracking-[0.3em] mb-2"
				style="font-family: 'Old Standard TT', serif; color: #6b5c4a;"
			>
				Chapter I
			</p>
			<h2
				class="text-3xl mb-8"
				style="font-family: 'Lora', serif; color: #f5f0e8;"
			>
				The Problem
			</h2>
			<p
				class="text-lg leading-relaxed mb-8"
				style="font-family: 'Old Standard TT', serif; color: #a89070;"
			>
				{problem.text}
			</p>
		</div>
	</section>

	<!-- Chapter II: The Solution -->
	<section class="px-6 py-20">
		<div class="max-w-2xl mx-auto">
			<p
				class="text-xs uppercase tracking-[0.3em] mb-2"
				style="font-family: 'Old Standard TT', serif; color: #6b5c4a;"
			>
				Chapter II
			</p>
			<h2
				class="text-3xl mb-8"
				style="font-family: 'Lora', serif; color: #f5f0e8;"
			>
				The Solution
			</h2>
			<p
				class="text-lg leading-relaxed"
				style="font-family: 'Old Standard TT', serif; color: #a89070;"
			>
				{problem.solution}
			</p>
		</div>
	</section>

	<!-- Divider -->
	<div class="max-w-2xl mx-auto px-6">
		<hr style="border-color: rgba(162, 144, 112, 0.2);" />
	</div>

	<!-- Chapter III: The Proof (Benchmark) -->
	<section class="px-6 py-20">
		<div class="max-w-2xl mx-auto">
			<p
				class="text-xs uppercase tracking-[0.3em] mb-2"
				style="font-family: 'Old Standard TT', serif; color: #6b5c4a;"
			>
				Chapter III
			</p>
			<h2
				class="text-3xl mb-8"
				style="font-family: 'Lora', serif; color: #f5f0e8;"
			>
				The Proof
			</h2>
			<h3
				class="text-xl mb-6"
				style="font-family: 'Lora', serif; color: #d4c4a8;"
			>
				{benchmark.book}
			</h3>
			<div
				class="grid grid-cols-2 sm:grid-cols-4 gap-6 mb-8"
				style="font-family: 'Old Standard TT', serif;"
			>
				<div>
					<p class="text-xs uppercase tracking-wider mb-1" style="color: #6b5c4a;">
						Pages
					</p>
					<p style="color: #d4c4a8;">{benchmark.pages}</p>
				</div>
				<div>
					<p class="text-xs uppercase tracking-wider mb-1" style="color: #6b5c4a;">
						Time
					</p>
					<p style="color: #d4c4a8;">{benchmark.time}</p>
				</div>
				<div>
					<p class="text-xs uppercase tracking-wider mb-1" style="color: #6b5c4a;">
						Cost
					</p>
					<p style="color: #d4c4a8;">{benchmark.cost}</p>
				</div>
				<div>
					<p class="text-xs uppercase tracking-wider mb-1" style="color: #6b5c4a;">
						Output
					</p>
					<p style="color: #d4c4a8;">{benchmark.output}</p>
				</div>
			</div>
			<p
				class="text-sm leading-relaxed"
				style="font-family: 'Old Standard TT', serif; color: #7a6b58;"
			>
				{benchmark.costNote}
			</p>
		</div>
	</section>

	<!-- Divider -->
	<div class="max-w-2xl mx-auto px-6">
		<hr style="border-color: rgba(162, 144, 112, 0.2);" />
	</div>

	<!-- Chapter IV: The Output -->
	<section class="px-6 py-20">
		<div class="max-w-2xl mx-auto">
			<p
				class="text-xs uppercase tracking-[0.3em] mb-2"
				style="font-family: 'Old Standard TT', serif; color: #6b5c4a;"
			>
				Chapter IV
			</p>
			<h2
				class="text-3xl mb-4"
				style="font-family: 'Lora', serif; color: #f5f0e8;"
			>
				The Output
			</h2>
			<p
				class="text-base leading-relaxed mb-10"
				style="font-family: 'Old Standard TT', serif; color: #a89070;"
			>
				Here's what the plugin produced from <em style="color: #d4c4a8;">{output.book}</em>, a real 400-page book, processed in 42 minutes.
			</p>

			<!-- Overview excerpt -->
			<p
				class="text-xs uppercase tracking-wider mb-3"
				style="font-family: 'Old Standard TT', serif; color: #6b5c4a;"
			>
				30-Second Overview
			</p>
			<div
				class="px-5 py-4 rounded mb-10 overflow-x-auto"
				style="background: rgba(0, 0, 0, 0.3); border: 1px solid rgba(162, 144, 112, 0.1);"
			>
				<pre
					class="text-sm leading-relaxed whitespace-pre-wrap"
					style="font-family: 'JetBrains Mono', monospace; color: #a89070;"
				>{output.overview}</pre>
			</div>

			<!-- Situational index excerpt -->
			<p
				class="text-xs uppercase tracking-wider mb-3"
				style="font-family: 'Old Standard TT', serif; color: #6b5c4a;"
			>
				Situational Index
			</p>
			<div
				class="px-5 py-4 rounded overflow-x-auto"
				style="background: rgba(0, 0, 0, 0.3); border: 1px solid rgba(162, 144, 112, 0.1);"
			>
				<pre
					class="text-sm leading-relaxed whitespace-pre-wrap"
					style="font-family: 'JetBrains Mono', monospace; color: #a89070;"
				>{output.index}</pre>
			</div>
		</div>
	</section>

	<!-- Divider -->
	<div class="max-w-2xl mx-auto px-6">
		<hr style="border-color: rgba(162, 144, 112, 0.2);" />
	</div>

	<!-- Chapter V: How It Works (Pipeline) -->
	<section class="px-6 py-20">
		<div class="max-w-2xl mx-auto">
			<p
				class="text-xs uppercase tracking-[0.3em] mb-2"
				style="font-family: 'Old Standard TT', serif; color: #6b5c4a;"
			>
				Chapter V
			</p>
			<h2
				class="text-3xl mb-4"
				style="font-family: 'Lora', serif; color: #f5f0e8;"
			>
				How It Works
			</h2>
			<p
				class="text-base leading-relaxed mb-12"
				style="font-family: 'Old Standard TT', serif; color: #a89070;"
			>
				{pipelineIntro}
			</p>

			<div class="relative pl-10">
				<!-- Vertical line -->
				<div
					class="absolute left-[11px] top-0 bottom-0 w-px"
					style="background: rgba(194, 83, 45, 0.25);"
				>
				</div>

				{
					pipeline.map((step) => (
						<div
							class="relative pb-10 last:pb-0"
							data-step={step.step}
						>
							{/* Node circle */}
							<div
								class="absolute left-[-34px] top-[3px] w-[23px] h-[23px] rounded-full border-2 flex items-center justify-center"
								style="border-color: #c2532d; background: transparent;"
							>
								<div
									class="w-[9px] h-[9px] rounded-full"
									style="background: #c2532d;"
								/>
							</div>

							{/* Step content */}
							<div>
								<div class="flex items-baseline gap-3 mb-1">
									<span
										class="text-sm"
										style="font-family: 'Lora', serif; color: #6b5c4a;"
									>
										{step.step}
									</span>
									<h3
										class="text-lg"
										style="font-family: 'Lora', serif; color: #d4c4a8;"
									>
										{step.name}
									</h3>
								</div>
								<p
									class="text-sm leading-relaxed"
									style="font-family: 'Old Standard TT', serif; color: #7a6b58;"
								>
									{step.description}
								</p>
							</div>
						</div>
					))
				}
			</div>
		</div>
	</section>

	<!-- Visual Workflow Diagram -->
	<section class="px-6 py-10">
		<div class="wf-canvas">

			<div class="wf-flow">

				<div class="wf-node wf-input">
					<div class="wf-badge">Input</div>
					<div class="wf-label">PDF / EPUB / Directory</div>
				</div>

				<div class="wf-conn wf-conn-terra" style="margin-bottom: -1px;"></div>
				
				<div class="wf-node wf-decision" id="wf-decision">
					<div class="wf-label">File or Dir?</div>
				</div>

				<div style="height: 18px"></div>

				<div class="wf-fork-labels">
					<span class="wf-fork-label">PDF / EPUB</span>
					<span class="wf-fork-label">Directory</span>
				</div>

				<div class="wf-fork-lines" id="wf-fork-lines-container"></div>

				<div class="wf-fork">
					<!-- Book Pipeline -->
					<div class="wf-pipeline" id="wf-book-pipeline">
						<div class="wf-pipeline-title">Book Pipeline</div>

						<div class="wf-node wf-process">
							<div class="wf-label">Chunk Document</div>
							<div class="wf-detail">chunk_document.ts<br/>Split into N-page segments</div>
						</div>
						<div class="wf-conn wf-conn-terra"></div>
						<div class="wf-node wf-ai">
							<div class="wf-badge">Parallel</div>
							<div class="wf-label">Pass 1: Extract</div>
							<div class="wf-detail">research-prompt.md<br/>5 chunks per batch</div>
							<div class="wf-dots"><span/><span/><span/><span/><span/></div>
						</div>
						<div class="wf-conn wf-conn-terra"></div>
						<div class="wf-node wf-ai">
							<div class="wf-badge">Single</div>
							<div class="wf-label">Pass 2: Cross-Reference</div>
							<div class="wf-detail">running-context.md<br/>terminology.md &middot; book-spine.md</div>
						</div>
						<div class="wf-conn wf-conn-terra"></div>
						<div class="wf-node wf-ai">
							<div class="wf-badge">Parallel</div>
							<div class="wf-label">Pass 3: Distill</div>
							<div class="wf-detail">Genre-specific criteria<br/>distilled-chunk-NNN.md</div>
							<div class="wf-dots"><span/><span/><span/><span/><span/></div>
						</div>
						<div class="wf-conn wf-conn-terra"></div>
						<div class="wf-node wf-process" id="wf-book-synth">
							<div class="wf-label">Synthesize</div>
							<div class="wf-detail">EXTRACTION_SUMMARY.md</div>
						</div>
					</div>

					<!-- Repo Pipeline -->
					<div class="wf-pipeline" id="wf-repo-pipeline">
						<div class="wf-pipeline-title">Repo Pipeline</div>

						<div class="wf-node wf-process">
							<div class="wf-label">Detect Exercises</div>
							<div class="wf-detail">detect_exercises.ts<br/>exercises_manifest.json</div>
						</div>
						<div class="wf-conn wf-conn-terra"></div>
						<div class="wf-node wf-ai">
							<div class="wf-badge">Parallel</div>
							<div class="wf-label">Extract Exercises</div>
							<div class="wf-detail">code-extraction-prompt.md<br/>problem → solution diffs</div>
							<div class="wf-dots"><span/><span/><span/><span/><span/></div>
						</div>
						<div class="wf-conn wf-conn-terra"></div>
						<div class="wf-node wf-process" id="wf-repo-synth">
							<div class="wf-label">Synthesize</div>
							<div class="wf-detail">Reference files per module</div>
						</div>
					</div>
				</div>

				<div style="height: 60px"></div>

				<div class="wf-section-label" id="wf-merge-target">Convert to Skill</div>

				<div class="wf-conn wf-conn-terra wf-conn-nodot"></div>

				<div class="wf-node wf-hero">
					<div class="wf-badge">Output</div>
					<div class="wf-label">Skill Package</div>
					<div class="wf-detail">
						SKILL.md + references/ + book.json<br/>
						8-15 reference files &middot; 3-level progressive disclosure
					</div>
				</div>

				<div class="wf-conn wf-conn-terra"></div>

				<div class="wf-node wf-process">
					<div class="wf-label">Fetch Cover Image</div>
					<div class="wf-detail">
						Goodreads → Open Library → Programmatic<br/>
						fetch_cover.ts &middot; generate_covers.ts
					</div>
				</div>

				<div class="wf-conn wf-conn-terra"></div>

				<div class="wf-node wf-process">
					<div class="wf-label">Install Skill</div>
					<div class="wf-detail">
						library | project | personal<br/>
						library_index.ts rebuilds index.json
					</div>
				</div>

				<div class="wf-conn wf-conn-terra wf-conn-long"></div>

				<hr class="wf-divider"/>

				<div style="text-align: center; margin-top: 8px">
					<div class="wf-section-label" style="margin-bottom: 10px">Library System</div>
					<div class="wf-node wf-terminal" style="display: inline-block">
						<div class="wf-label">/library &lt;name&gt;</div>
						<div class="wf-detail">
							~/.claude/library/books/&lt;name&gt;/<br/>
							list &middot; load &middot; search &middot; migrate &middot; rebuild
						</div>
					</div>
				</div>

			</div>
			<svg id="wf-merge-line" style="position:absolute;top:0;left:0;pointer-events:none;z-index:0;overflow:visible;"></svg>
		</div>
	</section>

	<!-- Divider -->
	<div class="max-w-2xl mx-auto px-6">
		<hr style="border-color: rgba(162, 144, 112, 0.2);" />
	</div>

	<!-- Chapter VI: Get Started -->
	<section class="px-6 py-20">
		<div class="max-w-2xl mx-auto">
			<p
				class="text-xs uppercase tracking-[0.3em] mb-2"
				style="font-family: 'Old Standard TT', serif; color: #6b5c4a;"
			>
				Chapter VI
			</p>
			<h2
				class="text-3xl mb-8"
				style="font-family: 'Lora', serif; color: #f5f0e8;"
			>
				Get Started
			</h2>

			<p
				class="text-base leading-relaxed mb-10"
				style="font-family: 'Old Standard TT', serif; color: #a89070;"
			>
				{install.intro}
			</p>

			<!-- Prerequisites -->
			<p
				class="text-sm uppercase tracking-wider mb-3"
				style="font-family: 'Old Standard TT', serif; color: #6b5c4a;"
			>
				Prerequisites
			</p>
			<div class="flex gap-4 mb-10">
				{
					install.prerequisites.map((p) => (
						<span
							class="text-sm px-3 py-1 rounded"
							style="font-family: 'JetBrains Mono', monospace; color: #d4c4a8; background: rgba(162, 144, 112, 0.1); border: 1px solid rgba(162, 144, 112, 0.15);"
						>
							{p}
						</span>
					))
				}
			</div>

			<!-- Install commands -->
			<p
				class="text-sm uppercase tracking-wider mb-3"
				style="font-family: 'Old Standard TT', serif; color: #6b5c4a;"
			>
				Install
			</p>
			<div class="space-y-3 mb-10">
				{
					install.commands.map((cmd) => (
						<div>
							<p
								class="text-xs mb-1"
								style="font-family: 'Old Standard TT', serif; color: #6b5c4a;"
							>
								{cmd.label}
							</p>
							<div
								class="group relative px-4 py-3 rounded"
								style="background: rgba(0, 0, 0, 0.3); border: 1px solid rgba(162, 144, 112, 0.1);"
							>
								<code
									class="text-sm"
									style="font-family: 'JetBrains Mono', monospace; color: #c2532d;"
								>
									{cmd.command}
								</code>
								<button
									class="copy-btn absolute right-3 top-1/2 -translate-y-1/2 opacity-0 group-hover:opacity-100 transition-opacity cursor-pointer"
									data-copy={cmd.command}
									style="color: #6b5c4a;"
								>
									<svg
										class="w-4 h-4"
										fill="none"
										stroke="currentColor"
										viewBox="0 0 24 24"
									>
										<path
											stroke-linecap="round"
											stroke-linejoin="round"
											stroke-width="2"
											d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z"
										/>
									</svg>
								</button>
							</div>
						</div>
					))
				}
			</div>

			<!-- Quick Start -->
			<p
				class="text-sm uppercase tracking-wider mb-3"
				style="font-family: 'Old Standard TT', serif; color: #6b5c4a;"
			>
				Quick Start
			</p>
			<div class="space-y-3">
				{
					install.quickStart.map((cmd, i) => (
						<div class="flex items-start gap-4">
							<span
								class="text-sm mt-3 shrink-0"
								style="font-family: 'Lora', serif; color: #6b5c4a;"
							>
								{i + 1}.
							</span>
							<div class="flex-1">
								<p
									class="text-xs mb-1"
									style="font-family: 'Old Standard TT', serif; color: #6b5c4a;"
								>
									{cmd.label}
								</p>
								<div
									class="group relative px-4 py-3 rounded"
									style="background: rgba(0, 0, 0, 0.3); border: 1px solid rgba(162, 144, 112, 0.1);"
								>
									<code
										class="text-sm"
										style="font-family: 'JetBrains Mono', monospace; color: #c2532d;"
									>
										{cmd.command}
									</code>
									<button
										class="copy-btn absolute right-3 top-1/2 -translate-y-1/2 opacity-0 group-hover:opacity-100 transition-opacity cursor-pointer"
										data-copy={cmd.command}
										style="color: #6b5c4a;"
									>
										<svg
											class="w-4 h-4"
											fill="none"
											stroke="currentColor"
											viewBox="0 0 24 24"
										>
											<path
												stroke-linecap="round"
												stroke-linejoin="round"
												stroke-width="2"
												d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z"
											/>
										</svg>
									</button>
								</div>
							</div>
						</div>
					))
				}
			</div>
		</div>
	</section>

	<!-- Divider -->
	<div class="max-w-2xl mx-auto px-6">
		<hr style="border-color: rgba(162, 144, 112, 0.2);" />
	</div>

	<!-- Chapter VII: Your Library -->
	<section class="px-6 py-20">
		<div class="max-w-2xl mx-auto">
			<p
				class="text-xs uppercase tracking-[0.3em] mb-2"
				style="font-family: 'Old Standard TT', serif; color: #6b5c4a;"
			>
				Chapter VII
			</p>
			<h2
				class="text-3xl mb-4"
				style="font-family: 'Lora', serif; color: #f5f0e8;"
			>
				{companion.title}
			</h2>
			<p
				class="text-base leading-relaxed mb-10"
				style="font-family: 'Old Standard TT', serif; color: #a89070;"
			>
				{companion.description}
			</p>

			<a href={companion.repo} target="_blank" rel="noopener">
				<img
					src={companion.image}
					alt="Library View — visual book grid"
					class="w-full rounded mb-10"
					style="border: 1px solid rgba(162, 144, 112, 0.15);"
				/>
			</a>

			<div class="text-center">
				<a
					href={companion.repo}
					target="_blank"
					rel="noopener"
					class="inline-block px-6 py-3 rounded text-sm tracking-wider uppercase transition-colors"
					style="font-family: 'Old Standard TT', serif; color: #f5f0e8; background: rgba(194, 83, 45, 0.8); border: 1px solid #c2532d;"
				>
					View Library App
				</a>
			</div>
		</div>
	</section>

	<!-- Footer -->
	<footer class="px-6 py-12">
		<div class="max-w-2xl mx-auto text-center">
			<p class="text-xs" style="font-family: 'Old Standard TT', serif; color: #6b5c4a;">
				{plugin.name} v{plugin.version} &middot; {plugin.license} &middot;
				Built by <a
					href={author.github}
					target="_blank"
					rel="noopener"
					class="underline hover:no-underline"
					style="color: #a89070;"
				>{author.name}</a> &middot;
				<a
					href={plugin.repository}
					target="_blank"
					rel="noopener"
					class="underline hover:no-underline"
					style="color: #a89070;"
				>
					GitHub
				</a>
			</p>
		</div>
	</footer>
</div>

<style>

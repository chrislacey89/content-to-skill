	.wf-terminal .wf-label { color: #c2532d }

	/* Fork / Merge */
	.wf-fork {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: 60px;
		width: 100%;
		max-width: 820px;
	}
	.wf-pipeline {
		display: flex;
		flex-direction: column;
		align-items: center;
